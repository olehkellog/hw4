<h1><%= @place["name"] %></h1>

<% if session["user_id"] != nil %>
  <p>
    <a href="/entries/new?place_id=<%= @place["id"] %>" class="btn btn-primary">New Post</a>
  </p>
<% end %>

<div class="row">
  <% for entry in @entries %>
    <div class="col-md-4">
      <h3><%= entry["title"] %></h3>
      <h4><%= entry["occurred_on"] %></h4>
      <% if entry.photo.attached? %>
        <img src="<%= url_for(entry.photo) %>" class="img-fluid">
      <% end %>
      <p><%= entry["description"] %></p>
    </div>
  <% end %>
</div>

<p>
  <a href="/places" class="btn btn-secondary">Back to All Places</a>
</p>
